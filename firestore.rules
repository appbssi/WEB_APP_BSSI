rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ACCÈS TOTAL ET ILLIMITÉ - RÉSOLUTION DÉFINITIVE DES ERREURS DE PERMISSIONS
    // Mise à jour forcée pour garantir le déploiement des règles ouvertes
    // Commentaire ajouté pour déclencher un redéploiement complet des règles.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}